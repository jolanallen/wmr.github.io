		{"id":"dd2cefe502c97db7","type":"text","text":"# HASH  FOUND (NetNTLMv1)","x":-12927,"y":-4452,"width":449,"height":55,"color":"2"},
		{"id":"d33cbbd0bdfc7aca","type":"text","text":"# HASH  FOUND (NetNTLMv2)","x":-12927,"y":-4372,"width":449,"height":55,"color":"2"},
		{"id":"2a7e33149d721ade","type":"text","text":"# RELAY","x":-12927,"y":-4292,"width":169,"height":55,"color":"3"},
		{"id":"6db4139728bcc068","type":"text","text":"# RELAY","x":-12927,"y":-3904,"width":169,"height":55,"color":"3"},
